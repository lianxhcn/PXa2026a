# ============================================================
# PXa2026a · .gitignore
# 原则：私有过程文件、素材、agent 指南与本地生成的调用入口一律不推送远程；
#       但 docs/ 是 GitHub Pages 发布源，绝不忽略。
# ============================================================

# --- 永不推送的私有目录（CLAUDE.md 规则 2）---
/working/
/_task/
/_materials/
/_backup/
/_temp_download/

# --- agent 指南（本地使用，不入公开仓库）---
/CLAUDE.md
/AGENTS.md

# --- 由 setup 脚本本地生成的调用入口（skills 唯一权威源是 skills/）---
/.claude/
/.agents/

# --- Quarto 中间产物（保留 docs/ 作为发布源，勿忽略）---
/.quarto/
*.rmarkdown
/lectures/*_files/
/appendix/*_files/
/*_files/

# --- 编辑器与系统杂项 ---
.DS_Store
Thumbs.db
*.log
*.stswp
*.stpr

# --- 课堂示例运行时生成的中间数据 ---
/examples/ch02/firm_finance_2021_2022.dta
/examples/ch02/industry_lookup_upper.dta
/examples/ch02/data/firm_finance_2021_2022.dta
/examples/ch02/data/industry_lookup_upper.dta

# --- Python ---
__pycache__/
*.pyc
.ipynb_checkpoints/

# 离线分发包(本地留存,不推送)
/_dist/

# Baker (2026) 复现中由 Stata 临时安装的外部命令缓存。
# 保留课程脚本、数据和说明；学员应按相应 do-file/说明自行安装命令。
/examples/Baker-*/**/ado/
/examples/Baker-*/**/plus/
/examples/Baker-*/**/personal/
/examples/Baker-*/**/site/
/examples/Baker-*/**/updates/
